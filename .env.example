# FDE Pulse newsletter env vars (server only — copy to .env on server)

# Resend API key (transactional sending)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx

# Newsletter worker API secret (must match the secret set on the Cloudflare Worker)
# Used for: D1 subscriber fetch + /track/send logging
API_SECRET=xxxxxxxxxx
